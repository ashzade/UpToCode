  "feature": {
    "name": "Contact Form",
    "intent": "Allows visitors to submit a contact message. No authentication required."
  },
  "externalProviders": {},
  "stateMachine": {
    "states": {},
    "transitions": []
  },
  "actors": {},
  "enforcement": [],
  "dataModel": {
    "ContactMessage": {
      "fields": {
        "id": {
          "name": "id",
          "type": "uuid",
          "modifiers": [
            {
              "name": "primary",
              "args": []
            },
            {
              "name": "auto-gen",
              "args": []
            }
          ]
        },
        "name": {
          "name": "name",
          "type": "string",
          "modifiers": [
            {
              "name": "required",
              "args": []
            }
          ]
        },
        "email": {
          "name": "email",
          "type": "string",
          "modifiers": [
            {
              "name": "required",
              "args": []
            },
            {
              "name": "regex",
              "args": [
                "/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/"
              ]
            },
            {
              "name": "pii",
              "args": []
            }
          ]
        },
        "body": {
          "name": "body",
          "type": "string",
          "modifiers": [
            {
              "name": "required",
              "args": []
            }
          ]
        },
        "created_at": {
          "name": "created_at",
          "type": "timestamp",
          "modifiers": [
            {
              "name": "auto-gen",
              "args": []
            }
          ]
        }
      }
    }
  },
  "computedProperties": {},
  "rules": {
    "RULE_01": {
      "id": "RULE_01",
      "title": "Email Format Valid",
      "references": [],
      "type": "Validation",
      "entity": "ContactMessage",
      "condition": "entity.email != ''",
      "message": "A valid email address is required."
    },
    "RULE_02": {
      "id": "RULE_02",
      "title": "Body Not Empty",
      "references": [],
      "type": "Validation",
      "entity": "ContactMessage",
      "condition": "entity.body != ''",
      "message": "Message body cannot be empty."
    }
  }
}
