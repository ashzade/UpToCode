  "computedProperties": {},
  "rules": {
    "RULE_01": {
      "id": "RULE_01",
      "title": "Post Has Title and Body",
      "references": [],
      "type": "Validation",
      "entity": "Post",
      "condition": "entity.title != '' AND entity.body != ''",
      "message": "Post must have a title and body before publishing."
    },
    "RULE_02": {
      "id": "RULE_02",
      "title": "Only Author or Admin Can Archive",
      "references": [],
      "type": "Business",
      "entity": "Post",
      "condition": "actor.type == 'Author' OR actor.type == 'Admin'",
      "message": "Only the post author or an admin can archive a post."
    },
    "RULE_SEC_01": {
      "id": "RULE_SEC_01",
      "title": "Reader Cannot Write",
      "references": [],
      "type": "Security",
      "entity": "Post",
      "condition": "actor.type != 'Reader'",
      "message": "Readers do not have write access."
    }
  }
}
