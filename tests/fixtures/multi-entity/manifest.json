{
  "meta": {
    "featureId": "blog",
    "version": "1.0.0",
    "status": "approved",
    "owner": "content-team",
    "dependsOn": [],
    "tags": [
      "content",
      "publishing"
    ]
  },
  "feature": {
    "name": "Blog Publishing",
    "intent": "Authors can create and publish posts. Readers can leave comments on published posts. Admins can remove any post or comment."
  },
  "externalProviders": {},
  "stateMachine": {
    "states": {
      "DRAFT": "post created, not visible to readers",
      "PUBLISHED": "post is publicly visible",
      "ARCHIVED": "post hidden from readers, retained for records"
    },
    "transitions": [
      {
        "from": "DRAFT",
        "to": "PUBLISHED",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "POST_PUBLISHED"
            ]
          }
        ],
        "trigger": "Author clicks Publish",
        "guard": "RULE_01"
      },
      {
        "from": "PUBLISHED",
        "to": "ARCHIVED",
        "actions": [
          {
            "type": "emit_event",
            "args": [
              "POST_ARCHIVED"
            ]
          }
        ],
        "trigger": "Author or Admin archives post",
        "guard": "RULE_02"
      },
      {
        "from": "PUBLISHED",
        "to": "DRAFT",
        "actions": [],
        "trigger": "Author unpublishes post"
      }
    ]
  },
  "actors": {
    "Reader": {
      "read": [
        "Post.title",
        "Post.body",
        "Post.published_at",
        "Comment.body",
        "Comment.author_id"
      ],
      "write": "none"
    },
    "Author": {
      "read": "*",
      "write": [
        "Post.title",
        "Post.body",
        "Post.status"
      ]
    },
    "Admin": {
      "read": "none",
      "write": [
        "Post.status",
        "Comment.is_removed"
      ],
      "inherits": "Author"
    }
  },
  "enforcement": [
    {
      "ruleId": "RULE_SEC_01",
      "severity": "CRITICAL",
      "responses": [
        {
          "action": "reject"
        },
        {
          "action": "audit_log"
        }
      ]
    },
    {
      "ruleId": "RULE_02",
      "severity": "HIGH",
      "responses": [
        {
          "action": "reject"
        },
        {
          "action": "audit_log"
        }
      ]
    }
  ],
